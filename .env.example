# Database Configuration
# For SQLite: file:./dev.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL="file:./dev.db"

# Node Environment
NODE_ENV="development"

# JWT Secret for Authentication
JWT_SECRET="your-super-secret-key-change-in-production"

# One-time secret used only to bootstrap the first admin account
ADMIN_BOOTSTRAP_SECRET="change-this-before-first-admin-creation"

# Gemini API Key
GEMINI_API_KEY="AIzaSyCAksC9z2wxB-cd_LO0HesjxKcwby5V1Cs"

# App URL
APP_URL="http://localhost:3000"

# Server Port
PORT="3000"
